# IntegraTax Middleware — Environment Variables
# Copy this file to .env and fill in real values before starting.
# NEVER commit the .env file to version control.

# ── Server ────────────────────────────────────────────────────────────────────
# TCP port for the middleware to listen on.
PORT=3000

# ── Upstream SIMPBB API ───────────────────────────────────────────────────────
# REQUIRED in production. Base URL of the upstream SIMPBB oRPC server.
# Do NOT include a trailing slash.
SIMPBB_BASE_URL=https://simpbb.technosmart.id/api/rpc

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret between the Flutter app and this middleware.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank (or unset) to disable authentication — ONLY for local development.
INTEGRATAX_API_KEY=

# Allowed CORS origin(s) for browser-based clients.
# For multiple origins, comma-separate them:
#   ALLOWED_ORIGIN=https://integratax.bapenda.go.id,http://localhost:8080
ALLOWED_ORIGIN=http://localhost:8080

# ── Node Environment ──────────────────────────────────────────────────────────
# Set to "production" when deploying. In production, SIMPBB_BASE_URL is required.
NODE_ENV=development
